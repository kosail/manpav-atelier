---
interface Props {
    id: string;
    title: string;
    image: string;
    aspect: "portrait" | "landscape" | "square";
    category: string;
    year: number;
}

const {
    id,
    title,
    image,
    aspect = "portrait",
    category,
    year
} = Astro.props;

const aspectClass = {
    portrait: "aspect-portrait",
    landscape: "aspect-landscape",
    square: "aspect-square"
}[aspect];

const site = import.meta.env.SITE + import.meta.env.BASE_URL;
---

<a href={`${site}/works/${id}`} class="project-card">
    <div class={`image-container ${aspectClass}`}>
        <img src={image} alt={title} loading="lazy"/>
    </div>

    <div class="content">
        <h3 class="title">{title}</h3>
        <span class="year">{year}</span>
    </div>

    <p class="category">{category}</p>
</a>

<style>
    .project-card {
        display: block;
        text-decoration: none;
        color: inherit;
    }

    .image-container {
        overflow: hidden;
        margin-bottom: 1.25rem;
    }

    .image-container img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.7s ease-out;
    }

    .project-card:hover img {
        transform: scale(1.03);
    }

    .content {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 0;
    }

    .title {
        font-size: 1.25rem;
        font-weight: 500;
        transition: color 0.3s;
        margin: 0; /* remove default h3 margin */
    }

    .project-card:hover .title {
        color: var(--color-primary);
    }

    .year {
        flex-shrink: 0;
        font-weight: 300;
        font-size: 0.875rem;
        color: var(--color-text-slight);
        letter-spacing: 0.05em;
    }

    .category {
        margin-top: 0.5rem;
        text-transform: uppercase;
        font-weight: 300;
        font-size: 0.875rem;
        color: var(--color-text-slight);
        letter-spacing: 0.05em;
    }

    /* Aspect ratios */
    .aspect-portrait {
        aspect-ratio: 3 / 4;
    }

    .aspect-landscape {
        aspect-ratio: 4 / 3;
    }

    .aspect-square {
        aspect-ratio: 1 / 1;
    }

    /* Desktop */
    @media (min-width: 768px) {
        .title {
            font-size: 1.5rem;
        }
    }
</style>