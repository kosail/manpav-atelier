---
import EmailButton from "@components/EmailButton.astro";

const year: number = new Date().getFullYear();
const site = import.meta.env.SITE + import.meta.env.BASE_URL;
---

<footer>
    <a href={site} class="pageTitle playfair">Manpav</a>
    <p class="subtitle">Thoughtful work emerges from attention. If the message matters, the form must earn it.</p>
    <EmailButton/>
    <p class="copyright">© 2021 - {year} Manpav Atelier. All rights reserved.</p>
</footer>

<style>
    footer {
        padding: 2rem 0;
        border-top: 1px solid var(--color-text-slightest);
        max-width: 1440px;
        display: flex;
        flex-direction: column;
        align-items: center;
        margin: 0 auto;
    }

    .pageTitle {
        font-size: 24px;
        margin-bottom: 1rem;
        align-self: flex-start;
    }

    .subtitle {
        font-size: 16px;
        margin-bottom: 1rem;
        align-self: flex-start;
        color: var(--color-text-slight);
    }

    .copyright {
        text-align: center;
        color: var(--color-text-slight);
        font-size: 12px;
    }
</style>