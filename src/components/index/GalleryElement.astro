---
import {Picture} from "astro:assets";

interface Props {
    image: any; // TODO: Replace this with the correct type ASAP
    alt: string;
    class?: string;
}

const {image, alt, class: className} = Astro.props;
---


<div class={className}>
    <Picture
            src={image}
            formats={['webp', 'jpg']}
            alt={alt}
            class="gallery-image"
    />
</div>

<style>
    .gallery-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: grayscale(100%);
        transition: filter 1s ease-in-out;
    }

    img.active {
        filter: grayscale(0%);
    }

    .v-stretch {
        grid-row: span 1;
    }

    .h-stretch {
        grid-column: span 1;
    }

    .big-stretch {
        grid-row: span 1;
        grid-column: span 1;
    }

    @media (min-width: 768px) {
        .v-stretch {
            grid-row: span 2;
        }

        .h-stretch {
            grid-column: span 2;
        }

        .big-stretch {
            grid-row: span 2;
            grid-column: span 2;
        }
    }
</style>