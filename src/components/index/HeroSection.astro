---
import {Picture} from "astro:assets";
import hero from "@assets/kuo-chiao-lin-4upJkLW4PFg-unsplash.webp";
---

<div class="hero">
    <div class="top-container">
        <h1 class="hero-text">Design that listen<span class="break"></span> before it<span class="break"></span> <em>speaks</em></h1>
        <p class="hero-subtitle">Each project begins in observation. Meaning is shaped through <span class="break"></span>structure, restraint, and intent—where typography carries<span class="break"></span> voice and images carry weight.<span class="break"></span> The result is not decoration, but communication that holds.</p>
    </div>

    <div class="bottom-container">
        <Picture src={hero}
                 formats={['avif', 'webp']}
                 alt="hero image"
        />
    </div>
</div>

<style>
    .hero {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        height: 90vh;
        width: 100%;
    }

    .top-container {
        display: flex;
        flex: 1;
        flex-direction: column;
        justify-content: center;
        align-items: flex-start;
        padding-left: 10px;
        width: 100%;
    }

    .bottom-container {
        flex: 1;
        display: flex;
    }

    .bottom-container img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: grayscale(100%);
    }

    .hero-text {
        font-size: 2.4rem;
    }

    .hero-subtitle {
        font-size: 1.1rem;
        align-self: flex-end;
        color: var(--color-text-slight);
    }

    .break {
        display: none;
    }

    @media (max-width: 767px) and (max-height: 720px) {
        .hero-text {
            margin-top: 0;
        }
    }

    @media (min-width: 768px) and (min-height: 721px) {
        .top-container {
            flex-direction: row;
            align-items: flex-start;
            padding-left: 0;
        }

        .hero-text {
            font-size: 4rem;
        }

        .hero-subtitle {
            padding-bottom: 8vh;
        }

        .break {
            display: inline;

            &::after {
                content: "\A";
                white-space: pre;
            }
        }
    }
</style>