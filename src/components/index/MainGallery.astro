---
import GalleryElement from "@components/index/GalleryElement.astro";
import image1 from "@assets/gallery/1.webp";
import image2 from "@assets/gallery/2.webp";
import image3 from "@assets/gallery/3.webp";
import image4 from "@assets/gallery/4.webp";
import image5 from "@assets/gallery/5.webp";
import image7 from "@assets/gallery/7.webp";
import image8 from "@assets/gallery/8.webp";
import image9 from "@assets/gallery/9.webp";
import image10 from "@assets/gallery/10.webp";
import image11 from "@assets/gallery/11.webp";
import image12 from "@assets/gallery/12.webp";
import image13 from "@assets/gallery/13.webp";
import image14 from "@assets/gallery/14.webp";
import image15 from "@assets/gallery/15.webp";
import image16 from "@assets/gallery/16.webp";
import image17 from "@assets/gallery/17.webp";
import image18 from "@assets/gallery/18.webp";
import image19 from "@assets/gallery/19.webp";
import image20 from "@assets/gallery/20.webp";
import image24 from "@assets/gallery/24.webp";
import image25 from "@assets/gallery/25.webp";
import image26 from "@assets/gallery/26.webp";
import image27 from "@assets/gallery/27.webp";

const images = [
    {src: image17, alt: "", class: "big-stretch"},
    {src: image1, alt: "", class: "v-stretch"},
    {src: image12, alt: "", class: "v-stretch"},
    {src: image2, alt: "", class: "v-stretch"},
    {src: image3, alt: "", class: "big-stretch"},
    {src: image11, alt: "", class: "v-stretch"},
    {src: image10, alt: "", class: "v-stretch"},
    {src: image4, alt: "", class: "v-stretch"},
    {src: image20, alt: "", class: "big-stretch"},
    {src: image24, alt: "", class: "v-stretch"},
    {src: image25, alt: "", class: "v-stretch"},
    {src: image26, alt: "", class: "v-stretch"},
    {src: image5, alt: "", class: "v-stretch"},
    {src: image7, alt: "", class: "v-stretch"},
    {src: image8, alt: "", class: "v-stretch"},
    {src: image9, alt: "", class: "v-stretch"},
    {src: image13, alt: "", class: "v-stretch"},
    {src: image14, alt: "", class: "v-stretch"},
    {src: image15, alt: "", class: "v-stretch"},
    {src: image18, alt: "", class: "big-stretch"},
    {src: image16, alt: "", class: "big-stretch"},
    {src: image19, alt: "", class: "big-stretch"},
    {src: image27, alt: "", class: "big-stretch"}
];
---

<div class="gallery">
    {
        images.map((image) =>
                <GalleryElement image={image.src} alt={image.alt} class={image.class}/>)
    }
</div>


<style>
    .gallery {
        padding: 10px;
        margin: 0 auto;
        display: grid;
        grid-gap: 50px;
        grid-template-columns: repeat(auto-fill, minmax(auto, 1fr));
        grid-auto-rows: 250px;
        grid-auto-flow: dense;
    }
</style>

<script>
    let observer: IntersectionObserver;

    function setupGallery() {
        if (observer) observer.disconnect();

        const container = document.querySelector('.gallery');
        const elements = container?.querySelectorAll('img') ?? [];

        observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                entry.target.classList.toggle('active', entry.isIntersecting);
            });
        }, {threshold: 0.3});

        elements.forEach(el => observer.observe(el));
    }

    document.addEventListener("astro:page-load", setupGallery);
    setupGallery(); // First load may miss the previous event listener
</script>