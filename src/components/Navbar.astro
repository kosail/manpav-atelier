---
interface Props {
    class?: string;
}

const {class: className} = Astro.props;

const site = import.meta.env.SITE + import.meta.env.BASE_URL;
const worksUrl = `${site}/works`;
const aboutUrl = `${site}/about`;
---

<nav class={className}>
    <div class="main-container">
        <a class="pageTitle playfair" href={site}>MANUEL PAVÓN</a>

        <button class="menu-button" id="menu-button">
            <svg width="24px" height="24px" fill="none">
                <path d="M3 5H21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M3 12H21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M3 19H21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
        </button>
    </div>

    <div class="menu-container" id="menu-container">
        <a class="menu-entry playfair" href={worksUrl}>WORKS</a>
        <a class="menu-entry playfair" href={aboutUrl}>MORE ABOUT ME</a>
    </div>
</nav>

<style>
    nav {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        align-items: center;
        margin-top: 0.4rem;
        padding: 0 1rem;
        max-width: 100%;
    }

    .main-container {
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        align-items: center;
        width: 100%;
    }

    .menu-container {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 1rem;

        width: 100%;
        margin-top: 1.2rem;

        max-height: 0;
        overflow: hidden;
        opacity: 0;

        transform: translateY(-10px);
        transition: max-height 0.4s ease,
        opacity 0.3s ease,
        transform 0.3s ease;
    }

    a.menu-entry {
        font-size: 1.4rem;
        letter-spacing: 0.1rem;

        &:hover {
            color: var(--color-primary);
            transition: color 0.3s;
        }
    }

    a.pageTitle {
        text-decoration: none;
        color: var(--color-text);
        font-size: 1.5rem;
        cursor: pointer;
    }

    .menu-button {
        height: 24px;
        width: 24px;
        background: none;
        border: none;
        cursor: pointer;
    }
</style>

<script>
    function initMenu() {
        const menuButton = document.getElementById('menu-button');
        const menuContainer = document.getElementById('menu-container');

        if (!menuButton || !menuContainer) return;

        let isMenuOpen = false;

        function toggleMenu() {
            isMenuOpen = !isMenuOpen;

            if (isMenuOpen) {
                menuContainer.style.transform = 'translateY(0)';
                menuContainer.style.maxHeight = '200px';
                menuContainer.style.opacity = '1';
            } else {
                menuContainer.style.transform = 'translateY(-10px)';
                menuContainer.style.maxHeight = '0';
                menuContainer.style.opacity = '0';
            }
        }

        // Remove any existing listener to avoid duplicates
        menuButton.removeEventListener('click', toggleMenu);
        menuButton.addEventListener('click', toggleMenu);
    }

    initMenu();
    document.addEventListener('astro:after-swap', initMenu);
</script>