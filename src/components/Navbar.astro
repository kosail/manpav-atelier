---
import MenuButton from "@components/MenuButton.astro";

interface Props {
    class?: string;
}

const { class: className } = Astro.props;
---
<nav class={className}>
    <a class="pageTitle playfair" href="/">MANUEL PAVÓN</a>
    <MenuButton />
</nav>

<style>
    nav {
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        align-items: center;
        padding: 0 1rem;
        height: 55px;
        max-width: 1400px;
        margin: 0 auto;
    }

    a.pageTitle {
        text-decoration: none;
        color: var(--color-text);
        font-size: 1.5rem;
        cursor: pointer;
    }
</style>