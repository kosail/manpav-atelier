---
import "@styles/global.css";
import Footer from "@components/Footer.astro";
import Navbar from "@components/Navbar.astro";
import LeftSidebar from "@components/LeftSidebar.astro";
import RightSidebar from "@components/RightSidebar.astro";
import {ClientRouter} from "astro:transitions";
import {Font} from "astro:assets";

interface Props {
    pageTitle: string;
}

const {pageTitle} = Astro.props;
const site = import.meta.env.SITE + import.meta.env.BASE_URL;
---

<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <meta name="generator" content={Astro.generator}/>

    <!-- META TAGS: GONNA REPLACE THIS IN THE FUTURE WITH PROPER ASTRO SEO -->
    <meta property="og:type" content="website"/>
    <meta property="og:title" content="Manpav Portafolio"/>
    <meta property="og:description" content="Professional graphic design services."/>
    <meta property="og:url" content={site}/>
    <meta property="og:image" content={`${site}/favicon.webp`}/>

    <meta name="twitter:card" content="summary_large_image"/>
    <meta name="twitter:title" content="Manpav Portafolio"/>
    <meta name="twitter:description" content="Professional graphic design services."/>
    <meta name="twitter:image" content={`${site}/favicon.webp`}/>
    <!-- META TAGS -->

    <link rel="icon" type="image/webp" href="favicon.webp"/>
    <link rel="icon" href="favicon.webp"/>

    <Font cssVariable="--font-playfair-display"/>
    <Font cssVariable="--font-dm-sans"/>

    <ClientRouter/>

    <title>{pageTitle} | Manpav Atelier</title>
</head>

<body>
<div class="page">
    <header class="navbar">
        <Navbar/>
    </header>

    <aside class="left">
        <LeftSidebar/>
    </aside>

    <main class="main-container">
        <slot/>
    </main>

    <aside class="right">
        <RightSidebar/>
    </aside>

    <footer class="footer">
        <Footer/>
    </footer>
</div>
</body>
</html>

<style>
    /* Mobile layout first */
    .page {
        display: grid;
        grid-template-columns: 1fr;
        grid-template-rows: auto 1fr auto;

        grid-template-areas:
            "navbar"
            "content"
            "footer";

        min-height: 100vh;
        max-width: 1440px;
        margin: 0 auto;
    }

    /* Hide sidebars on mobile by default */
    .left,
    .right {
        display: none;
    }

    /* Grid area assignments */
    .navbar {
        grid-area: navbar;
    }

    .main-container {
        grid-area: content;
    }

    .footer {
        grid-area: footer;
    }

    /* Desktop Layout - 768px and above */
    @media (min-width: 768px) {
        .page {
            grid-template-columns: 160px 1fr 160px;
            grid-template-rows: 1fr;
            grid-template-areas:
                "left content right";
        }

        .navbar {
            display: none;
        }

        .footer {
            display: none;
        }

        .left {
            display: flex;
            grid-area: left;
        }

        .main-container {
            grid-area: content;
        }

        .right {
            display: flex;
            grid-area: right;
        }
    }

</style>