---
import "@styles/global.css";
import Footer from "@components/Footer.astro";
import Navbar from "@components/Navbar.astro";
import LeftSidebar from "@components/LeftSidebar.astro";
import RightSidebar from "@components/RightSidebar.astro";
import {ClientRouter} from "astro:transitions";
import { Font } from "astro:assets";

interface Props {
    pageTitle: string;
}

let { pageTitle } = Astro.props;
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />

        <link rel="icon" type="image/webp" href="/favicon.webp" />
        <link rel="icon" href="/favicon.webp" />

        <Font cssVariable="--font-playfair-display" />
        <Font cssVariable="--font-dm-sans" />

        <ClientRouter />

        <title>{pageTitle}</title>
    </head>

    <body>
    <div class="page">
        <header class="navbar">
            <Navbar />
        </header>

        <aside class="left">
            <LeftSidebar />
        </aside>

        <main class="content">
            <slot />
        </main>

        <aside class="right">
            <RightSidebar />
        </aside>

        <footer class="footer">
            <Footer />
        </footer>
    </div>
    </body>
</html>

<style>
    /* Mobile layout first */
    .page {
        display: grid;
        grid-template-columns: 1fr;
        grid-template-rows: auto 1fr auto;

        grid-template-areas:
            "navbar"
            "content"
            "footer";

        min-height: 100vh;
        max-width: 1440px;
        margin: 0 auto;
    }

    /* Hide sidebars on mobile by default */
    .left,
    .right {
        display: none;
    }

    /* Grid area assignments */
    .navbar {
        grid-area: navbar;
    }

    .content {
        grid-area: content;
    }

    .footer {
        grid-area: footer;
    }

    /* Desktop Layout - 768px and above */
    @media(min-width: 768px) {
        .page {
            grid-template-columns: 160px 1fr 160px;
            grid-template-rows: 1fr;
            grid-template-areas:
                "left content right";
        }

        .navbar {
            display: none;
        }

        .footer {
            display: none;
        }

        .left {
            display: flex;
            grid-area: left;
        }

        .content {
            grid-area: content;
        }

        .right {
            display: flex;
            grid-area: right;
        }
    }

</style>